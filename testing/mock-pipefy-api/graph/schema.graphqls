type Card {
  id: ID!
  title: String!
  pipeId: Int!
  fields: [CardField!]!
}

type CardField {
  fieldId: String!
  fieldValue: String!
}

input FieldAttributeInput {
  fieldId: String!
  fieldValue: String!
}

input CreateCardInput {
  pipeId: Int!
  title: String!
  fieldsAttributes: [FieldAttributeInput!]!
}

input FieldValueInput {
  fieldId: String!
  value: String!
}

input UpdateFieldsValuesInput {
  nodeId: ID!
  values: [FieldValueInput!]!
}

type CreatedCard {
  title: String!
}

type CreateCardPayload {
  card: CreatedCard!
}

type UpdateFieldsValuesPayload {
  success: Boolean!
}

type Mutation {
  createCard(input: CreateCardInput!): CreateCardPayload!
  updateFieldsValues(input: UpdateFieldsValuesInput!): UpdateFieldsValuesPayload!
}